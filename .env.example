# Database (docker-compose defaults for local dev only — change in all other envs)
DATABASE_URL="postgresql://pm_user:pm_password@localhost:5432/pm_db"

# Auth.js — generate with: openssl rand -base64 32
# MUST be replaced in staging/production
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email (Resend in prod, Mailpit in dev)
EMAIL_FROM="noreply@localhost"
RESEND_API_KEY="re_..."
SMTP_HOST="localhost"
SMTP_PORT="1025"

# S3-compatible storage (MinIO in dev — change credentials in all non-local envs)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="pm-uploads"
S3_ACCESS_KEY_ID="pm_minio"
S3_SECRET_ACCESS_KEY="pm_minio_secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
