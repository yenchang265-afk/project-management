# Port 3307 = the Docker MariaDB from docker-compose.yml; native installs usually use 3306.
# Runtime app user (least privilege: no UPDATE/DELETE on events)
DATABASE_URL=mysql://cadence:cadence_dev_pw@localhost:3307/cadence
# Admin user for migrations + seeding (DDL rights)
DATABASE_ADMIN_URL=mysql://cadence_admin:cadence_admin_dev_pw@localhost:3307/cadence
# 32+ random bytes, hex/base64 — generate: openssl rand -hex 32
SESSION_SECRET=change_me_generate_a_real_secret
# Local dev only: skip login, act as a seed PM. Ignored when NODE_ENV=production.
# DEV_AUTH_BYPASS=1
# Shared secret for the scheduled-automation cron tick (POST /api/automations/tick
# with `Authorization: Bearer <secret>`). Unset = endpoint disabled (404).
# AUTOMATION_TICK_SECRET=change_me_generate_a_real_secret
# Anthropic API key for advisory AI suggestions (G-27). Unset = AI features
# disabled (the /api/ai/suggest endpoint returns 404, buttons show a note).
# ANTHROPIC_API_KEY=sk-ant-...
# SSO / OIDC (G-28). Set ALL FOUR to enable the "Sign in with SSO" button;
# unset = password auth only. Maps the verified id_token email to an existing
# users row (no auto-provisioning). Issuer must serve /.well-known/openid-configuration.
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback
