// Project Management — Prisma schema
// Phase 1: Auth.js core models + credentials/password-reset fields + RBAC roles.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEAD
  MEMBER
  VIEWER
}

model User {
  id                   String           @id @default(cuid())
  name                 String?
  email                String           @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  passwordResetToken   String?          @unique
  passwordResetExpires DateTime?
  accounts             Account[]
  sessions             Session[]
  memberships          OrgMembership[]
  ledProjects          Project[]        @relation("ProjectLead")
  projectMemberships   ProjectMember[]
  assignedIssues       Issue[]            @relation("IssueAssignee")
  reportedIssues       Issue[]            @relation("IssueReporter")
  comments             Comment[]
  attachments          Attachment[]
  activityEntries      ActivityLogEntry[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OrgMembership {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      Role
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  description String?
  leadId      String
  archivedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lead          User            @relation("ProjectLead", fields: [leadId], references: [id])
  members       ProjectMember[]
  issueCounter  IssueCounter?
  issues        Issue[]
  labels        Label[]
  sprints       Sprint[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model IssueCounter {
  projectId  String  @id
  lastNumber Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum IssueType {
  TASK
  BUG
  STORY
  EPIC
}

enum IssuePriority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  HIGHEST
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssueLinkType {
  BLOCKS
  RELATES_TO
  DUPLICATES
}

model Issue {
  id          String        @id @default(cuid())
  projectId   String
  number      Int
  key         String
  title       String
  description String?
  type        IssueType
  priority    IssuePriority @default(MEDIUM)
  status      IssueStatus   @default(TODO)
  assigneeId  String?
  reporterId  String
  dueDate     DateTime?
  estimate    Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?             @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User              @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  labels      IssueLabel[]
  comments    Comment[]
  attachments Attachment[]
  linksFrom   IssueLink[]       @relation("IssueLinkFrom")
  linksTo     IssueLink[]       @relation("IssueLinkTo")
  activity    ActivityLogEntry[]
  sprintIssues SprintIssue[]

  @@unique([projectId, number])
  @@unique([key])
  @@index([projectId, status])
}

model Label {
  id        String       @id @default(cuid())
  projectId String
  name      String
  color     String
  createdAt DateTime     @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  IssueLabel[]

  @@unique([projectId, name])
}

model IssueLabel {
  issueId String
  labelId String

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([issueId, createdAt])
}

model Attachment {
  id         String   @id @default(cuid())
  issueId    String
  uploaderId String
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime @default(now())

  issue    Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploader User  @relation(fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([issueId])
}

model IssueLink {
  id          String        @id @default(cuid())
  fromIssueId String
  toIssueId   String
  type        IssueLinkType
  createdAt   DateTime      @default(now())

  fromIssue Issue @relation("IssueLinkFrom", fields: [fromIssueId], references: [id], onDelete: Cascade)
  toIssue   Issue @relation("IssueLinkTo", fields: [toIssueId], references: [id], onDelete: Cascade)

  @@unique([fromIssueId, toIssueId, type])
}

model ActivityLogEntry {
  id       String   @id @default(cuid())
  issueId  String
  actorId  String
  field    String
  before   String?
  after    String?
  at       DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([issueId, at])
}

// Phase 4a — Boards / Search / Saved Filters
// SavedFilter stores a user-scoped filter spec (the same JSON shape that
// `listIssues` accepts) so the Boards / Backlog / Search UIs can recall it.
model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  name      String
  query     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

// Phase 4b — Sprints
enum SprintState {
  PLANNED
  ACTIVE
  COMPLETED
}

model Sprint {
  id          String      @id @default(cuid())
  projectId   String
  name        String
  goal        String?
  state       SprintState @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  SprintIssue[]

  @@index([projectId, state])
}

model SprintIssue {
  sprintId String
  issueId  String
  rank     Int

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  issue  Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@id([sprintId, issueId])
  @@unique([sprintId, rank])
}
